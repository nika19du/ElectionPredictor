@page "/predictions"
@rendermode InteractiveServer
@inject ElectionPredictor.Services.Interfaces.IPredictionService PredictionService

<h3>Election Predictions</h3>

<div class="mb-3">
    <label>Select Election Year:</label>
    <select class="form-select" @bind="selectedYear">
        <option value="2026">2026</option>
        <option value="2024">2024</option>
        <option value="2023">2023</option>
        <option value="2022">2022</option>
        <option value="2021">2021</option>
    </select>
</div>

<button class="btn btn-primary" @onclick="LoadPredictions">
    Generate Prediction
</button>

@if (predictions != null && predictions.Any())
{
    <hr />

    <h5>
        🏆 Winner: @predictions.First().PartyName
    </h5>

    <table class="table">
        <thead>
            <tr>
                <th>Party</th>
                <th>Predicted %</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in predictions)
            {
                <tr>
                    <td>@p.PartyName</td>
                    <td>@p.PredictedPercentage.ToString("0.00")%</td>
                </tr>
            }
        </tbody>
    </table>
}
else if (predictions != null)
{
    <p>No prediction data available.</p>
}

@code {
    private int selectedYear = 2024;
    private List<ElectionPredictor.Models.Dtos.PredictionDto>? predictions;

    private async Task LoadPredictions()
    {
        predictions = await PredictionService.GetSimplePredictionAsync(selectedYear);
    }
}